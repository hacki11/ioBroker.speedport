{
  "name": "iobroker.speedport",
  "version": "0.0.3",
  "description": "Fetches data from Telekom Speedport Router",
  "author": {
    "name": "hacki11",
    "email": "jur.schmid@gmail.com"
  },
  "contributors": [],
