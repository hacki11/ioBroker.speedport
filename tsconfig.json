{
    "extends": "@tsconfig/node22/tsconfig.json",
    "compilerOptions": {
        "allowJs": true,
        "checkJs": true,
        "noEmit": true,
        "strict": false,
        "noImplicitThis": false,
        "resolveJsonModule": true,
        "module": "NodeNext",
        "moduleResolution": "NodeNext",
        "noImplicitAny": false,
        "types": [
            "node",
            "iobroker",
            "mocha"
        ]
    },
    "include": [
        "**/*.js",
        "**/*.d.ts"
    ],
    "exclude": [
        "node_modules",
        "build",
        "dist",
        "widgets"
    ]
}
